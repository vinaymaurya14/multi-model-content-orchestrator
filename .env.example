# Multi-Model Content Orchestrator - Environment Variables
# Copy this file to .env and uncomment/fill in the values you need.

# ---------- Demo Mode ----------
# When true, the mock provider is used by default (no API keys required).
DEMO_MODE=true
DEFAULT_PROVIDER=mock

# ---------- OpenAI ----------
# OPENAI_API_KEY=sk-...
# OPENAI_ORG_ID=org-...

# ---------- Anthropic ----------
# ANTHROPIC_API_KEY=sk-ant-...

# ---------- HuggingFace ----------
# HF_API_TOKEN=hf_...

# ---------- Ollama (local) ----------
# OLLAMA_BASE_URL=http://localhost:11434

# ---------- Cost Controls ----------
# Maximum monthly spend in USD (0 = unlimited)
MONTHLY_COST_LIMIT=10.0
# Alert threshold as a fraction of the monthly limit (0.0 - 1.0)
COST_ALERT_THRESHOLD=0.8

# ---------- Server ----------
HOST=0.0.0.0
PORT=8002
LOG_LEVEL=info
